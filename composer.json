{
    "name": "byte-artist/byte-artist",
    "description": "web server environment for byte-artist web site",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-iconv": "*",
        "ext-mbstring": "*",
        "ext-xml": "*",
        "ext-zip": "*",
        "composer-runtime-api": "^2.0",
        "doctrine/doctrine-bundle": "^2.18",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6",
        "friendsofsymfony/ckeditor-bundle": "^2.1",
        "knpuniversity/oauth2-client-bundle": "^2.0",
        "league/oauth2-facebook": "^2.0",
        "league/oauth2-google": "^3.0",
        "pentatrion/vite-bundle": "^7.0",
        "scrivo/highlight.php": "^9.18",
        "symfony/console": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/flex": "^2",
        "symfony/form": "^7.2",
        "symfony/framework-bundle": "^7.2",
        "symfony/mime": "^7.2",
        "symfony/monolog-bundle": "^3.4",
        "symfony/password-hasher": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/security-bundle": "^7.2",
        "symfony/translation": "^7.2",
        "symfony/twig-bundle": "^7.2",
        "symfony/validator": "^7.2",
        "symfony/yaml": "^7.2"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.4",
        "friendsofphp/php-cs-fixer": "^3.0",
        "mikey179/vfsstream": "*",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-doctrine": "^1.3",
        "phpstan/phpstan-phpunit": "^1.3",
        "phpstan/phpstan-symfony": "^1.3",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.6",
        "symfony/browser-kit": "^7.2",
        "symfony/css-selector": "^7.2",
        "symfony/maker-bundle": "^1.12",
        "symfony/phpunit-bridge": "^7.2",
        "symfony/stopwatch": "^7.4",
        "symfony/web-profiler-bundle": "^7.4"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "bin-dir": "bin"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "phpstan": "phpstan analyse -c phpstan.neon src tests --level 5 --no-progress",
        "tests": "bin/simple-phpunit",
        "ci": [
            "@phpstan",
            "@tests"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "ckeditor:install --clear=drop": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    }
}
