<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="Andreas Kempe — Software Architect aus Dresden. Über 35 Jahre Erfahrung in der Softwareentwicklung. Open-Source Projekte, Blog, Erfahrungen.">
        <title>{% block title %}byte-artist.de{% endblock %}</title>
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
    </head>

    <body>
        <nav class="site-nav" id="site-nav">
            <div class="nav-inner">
                <a class="nav-logo" href="{{ path('index') }}">byte-artist</a>

                <ul class="nav-links">
                    <li><a href="{{ path('projects') }}"{% if app.request.attributes.get('_route') matches '{^project}' %} class="active"{% endif %}>Projekte</a></li>
                    <li><a href="{{ path('blog') }}"{% if app.request.attributes.get('_route') matches '{^blog}' %} class="active"{% endif %}>Blog</a></li>
                    <li><a href="{{ path('about') }}"{% if app.request.attributes.get('_route') == 'about' %} class="active"{% endif %}>Über mich</a></li>
                </ul>

                <form class="nav-search" method="get" action="{{ path('app_search_result') }}">
                    <button type="submit" aria-label="Suchen"><i class="fas fa-search"></i></button>
                    <input type="search" name="q" placeholder="Suche…" aria-label="Suche">
                </form>

                <div class="nav-user">
                    <button class="nav-user-btn" aria-label="Nutzerprofil"><i class="fas fa-user"></i></button>
                    <div class="nav-dropdown">
                        {% if app.user is not null and app.user.username is defined %}
                            <span>{{ app.user.username }}</span>
                            <a href="{{ path('app_logout') }}">Abmelden</a>
                        {% else %}
                            <a href="{{ path('app_login') }}">Anmelden</a>
                        {% endif %}
                    </div>
                </div>

                <button class="hamburger" id="nav-toggle" aria-label="Navigation öffnen">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <footer class="site-footer">
            <div class="footer-inner">
                <span class="footer-brand">byte-artist</span>
                <nav class="footer-links" aria-label="Footer Navigation">
                    <a href="{{ path('imprint') }}">Impressum</a>
                    <a href="{{ path('data_protection') }}">Datenschutz</a>
                </nav>
                <span class="footer-copy">© {{ "now"|date("Y") }} Andreas — Open Source mit ♥</span>
            </div>
        </footer>

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </body>
</html>
