<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="Andreas Kempe — Software Architect aus Dresden. Über 35 Jahre Erfahrung in der Softwareentwicklung. Open-Source Projekte, Blog, Erfahrungen.">
        <title>{% block title %}byte-artist.de{% endblock %}</title>
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    </head>

    <body>
        <nav class="site-nav" id="site-nav">
            <div class="nav-inner">
                <a class="nav-logo" href="{{ path('index') }}">byte-artist</a>

                <ul class="nav-links">
                    <li><a href="{{ path('projects') }}"{% if app.request.attributes.get('_route') matches '{^project}' %} class="active"{% endif %}>Projekte</a></li>
                    <li><a href="{{ path('blog') }}"{% if app.request.attributes.get('_route') matches '{^blog}' %} class="active"{% endif %}>Blog</a></li>
                    <li><a href="{{ path('about') }}"{% if app.request.attributes.get('_route') == 'about' %} class="active"{% endif %}>Über mich</a></li>
                </ul>

                <form class="nav-search" method="get" action="{{ path('app_search_result') }}">
                    <button type="submit" aria-label="Suchen"><i class="fas fa-search"></i></button>
                    <input type="search" name="q" placeholder="Suche…" aria-label="Suche">
                </form>

                <div class="nav-user">
                    <button class="nav-user-btn" aria-label="Nutzerprofil"><i class="fas fa-user"></i></button>
                    <div class="nav-dropdown">
                        {% if app.user is not null and app.user.username is defined %}
                            <span>{{ app.user.username }}</span>
                            <a href="{{ path('app_logout') }}">Abmelden</a>
                        {% else %}
                            <a href="{{ path('app_login') }}">Anmelden</a>
                        {% endif %}
                    </div>
                </div>

                <button class="hamburger" id="nav-toggle" aria-label="Navigation öffnen">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <footer class="site-footer">
            <div class="footer-inner">
                <span class="footer-brand">byte-artist</span>
                <nav class="footer-links" aria-label="Footer Navigation">
                    <a href="{{ path('imprint') }}">Impressum</a>
                    <a href="{{ path('data_protection') }}">Datenschutz</a>
                </nav>
                <span class="footer-copy">© {{ "now"|date("Y") }} Andreas — Open Source mit ♥</span>
            </div>
        </footer>

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
        <style>
        #toast-container{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none;}
        .toast{min-width:260px;max-width:420px;padding:12px 18px;border-radius:8px;font-size:14px;line-height:1.5;pointer-events:all;opacity:0;transform:translateY(10px);transition:opacity .22s,transform .22s;border:1px solid var(--border,#333);background:var(--bg-2,#1e1e1e);color:var(--text,#e0e0e0);white-space:pre-line;}
        .toast.toast--error{border-color:rgba(239,68,68,.5);background:rgba(239,68,68,.12);color:#fca5a5;}
        .toast.toast--success{border-color:rgba(34,197,94,.4);background:rgba(34,197,94,.1);color:#86efac;}
        .toast.toast--info{border-color:rgba(96,165,250,.4);background:rgba(96,165,250,.1);color:#93c5fd;}
        .toast.toast--show{opacity:1;transform:none;}
        </style>
        <script>
        function showToast(msg, type) {
            type = type || 'error';
            var c = document.getElementById('toast-container');
            if (!c) { c = document.createElement('div'); c.id = 'toast-container'; document.body.appendChild(c); }
            var t = document.createElement('div');
            t.className = 'toast toast--' + type;
            t.textContent = msg;
            c.appendChild(t);
            requestAnimationFrame(function(){ requestAnimationFrame(function(){ t.classList.add('toast--show'); }); });
            setTimeout(function(){ t.classList.remove('toast--show'); setTimeout(function(){ t.remove(); }, 300); }, 5000);
        }
        </script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
        <script>document.addEventListener('DOMContentLoaded', function(){ hljs.highlightAll(); });</script>
    </body>
</html>
