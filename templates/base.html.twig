<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="Andreas Kempe — Software Architect aus Dresden. Über 35 Jahre Erfahrung in der Softwareentwicklung. Open-Source Projekte, Blog, Erfahrungen.">
        <title>{% block title %}byte-artist.de{% endblock %}</title>
        {% block stylesheets %}
            {{ vite_entry_link_tags('app') }}
        {% endblock %}
        <link rel="stylesheet"
              href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css"
              integrity="sha384-oaMLBGEzBOJx3UHwac0cVndtX5fxGQIfnAeFZ35RTgqPcYlbprH9o9PUV/F8Le07"
              crossorigin="anonymous">
    </head>

    <body>
        <nav class="site-nav" id="site-nav">
            <div class="nav-inner">
                <a class="nav-logo" href="{{ path('index') }}">byte-artist</a>

                <ul class="nav-links">
                    <li><a href="{{ path('projects') }}"{% if app.request.attributes.get('_route') matches '{^project}' %} class="active"{% endif %}>Projekte</a></li>
                    <li><a href="{{ path('blog') }}"{% if app.request.attributes.get('_route') matches '{^blog}' %} class="active"{% endif %}>Blog</a></li>
                    <li><a href="{{ path('about') }}"{% if app.request.attributes.get('_route') == 'about' %} class="active"{% endif %}>Über mich</a></li>
                </ul>

                <form class="nav-search" method="get" action="{{ path('app_search_result') }}">
                    <button type="submit" aria-label="Suchen"><i class="fas fa-search"></i></button>
                    <input type="search" name="q" placeholder="Suche…" aria-label="Suche">
                </form>

                <div class="nav-user">
                    <button class="nav-user-btn" aria-label="Nutzerprofil"><i class="fas fa-user"></i></button>
                    <div class="nav-dropdown">
                        {% if app.user is not null and app.user.username is defined %}
                            <span>{{ app.user.username }}</span>
                            <a href="{{ path('app_logout') }}">Abmelden</a>
                        {% else %}
                            <a href="{{ path('app_login') }}">Anmelden</a>
                        {% endif %}
                    </div>
                </div>

                <button class="hamburger" id="nav-toggle" aria-label="Navigation öffnen">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <footer class="site-footer">
            <div class="footer-inner">
                <span class="footer-brand">byte-artist</span>
                <nav class="footer-links" aria-label="Footer Navigation">
                    <a href="{{ path('imprint') }}">Impressum</a>
                    <a href="{{ path('data_protection') }}">Datenschutz</a>
                </nav>
                <span class="footer-copy">© {{ "now"|date("Y") }} Andreas — Open Source mit ♥</span>
            </div>
        </footer>

        {% block javascripts %}
            {{ vite_entry_script_tags('app') }}
        {% endblock %}
        <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
                integrity="sha384-F/bZzf7p3Joyp5psL90p/p89AZJsndkSoGwRpXcZhleCWhd8SnRuoYo4d0yirjJp"
                crossorigin="anonymous"></script>
        <script>
        (function () {
            function makeLangFromClass(classList) {
                var lang = '';
                classList.forEach(function (c) {
                    if (c !== 'hljs' && !c.startsWith('language-')) lang = c.toUpperCase();
                    var m = c.match(/^language-(.+)$/);
                    if (m) lang = m[1].toUpperCase();
                });
                return lang;
            }

            function wrapPre(pre, lang) {
                if (pre.closest('.code-block')) return;
                // Unwrap <blockquote> that Tiptap may place around a code block
                var parent = pre.parentNode;
                if (parent && parent.tagName === 'BLOCKQUOTE') {
                    parent.parentNode.insertBefore(pre, parent);
                    parent.remove();
                }
                // Remove adjacent legacy chrome
                var s;
                s = pre.previousElementSibling;
                if (s && (s.classList.contains('code_header') || s.classList.contains('code_footer'))) s.remove();
                s = pre.nextElementSibling;
                if (s && (s.classList.contains('code_header') || s.classList.contains('code_footer'))) s.remove();

                var wrapper = document.createElement('div');
                wrapper.className = 'code-block';
                var header = document.createElement('div');
                header.className = 'code-block-header';
                header.innerHTML =
                    '<span class="code-block-lang"><i class="fas fa-code"></i> ' + (lang || 'CODE') + '</span>' +
                    '<button class="code-block-copy" type="button" title="In Zwischenablage kopieren">' +
                    '<i class="fas fa-copy"></i><span>Kopieren</span></button>';
                pre.parentNode.insertBefore(wrapper, pre);
                wrapper.appendChild(header);
                pre.classList.add('highlight_code');
                wrapper.appendChild(pre);
            }

            function fallbackCopy(text, cb) {
                var ta = document.createElement('textarea');
                ta.value = text;
                ta.style.cssText = 'position:fixed;opacity:0';
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand('copy'); cb(); } catch (e) {}
                document.body.removeChild(ta);
            }

            document.addEventListener('DOMContentLoaded', function () {
                // ── Step 1: Wrap OLD server-rendered blocks (code.hljs) ──
                // Mark data-highlighted so hljs.highlightAll() skips them.
                document.querySelectorAll('.project-detail-body pre > code.hljs').forEach(function (code) {
                    code.setAttribute('data-highlighted', 'yes');
                    wrapPre(code.parentElement, makeLangFromClass(code.classList));
                });

                // ── Step 2: Highlight raw Tiptap blocks ──────────────────
                // Trim leading/trailing newlines Tiptap adds to code blocks
                document.querySelectorAll('.project-detail-body pre > code[class*="language-"]').forEach(function (code) {
                    code.textContent = code.textContent.replace(/^\n/, '').replace(/\n$/, '');
                });
                hljs.highlightAll();

                // ── Step 3: Wrap freshly highlighted Tiptap blocks ───────
                document.querySelectorAll('.project-detail-body pre > code[class*="language-"]').forEach(function (code) {
                    wrapPre(code.parentElement, makeLangFromClass(code.classList));
                });

                // ── Copy-to-clipboard (event delegation) ─────────────────
                document.addEventListener('click', function (e) {
                    var btn = e.target.closest('.code-block-copy');
                    if (!btn) return;
                    var code = btn.closest('.code-block').querySelector('code');
                    if (!code) return;
                    var text = code.innerText;
                    var span = btn.querySelector('span');
                    function showCopied() {
                        btn.classList.add('copied');
                        span.textContent = 'Kopiert!';
                        setTimeout(function () {
                            btn.classList.remove('copied');
                            span.textContent = 'Kopieren';
                        }, 2200);
                    }
                    if (navigator.clipboard) {
                        navigator.clipboard.writeText(text).then(showCopied).catch(function () { fallbackCopy(text, showCopied); });
                    } else {
                        fallbackCopy(text, showCopied);
                    }
                });
            });
        }());
        </script>
    </body>
</html>
