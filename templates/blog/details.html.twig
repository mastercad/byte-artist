<div class="project-detail">
    <div class="project-detail-header">
        {% if is_granted('edit', blog) %}
        <div class="project-detail-actions">
            <a class="btn-secondary" style="padding:8px 16px;font-size:13px;" href="/blog/create/{{ blog.id }}">
                <i class="fas fa-edit"></i> Bearbeiten
            </a>
        </div>
        {% endif %}
        <h1>{{ blog.name }}</h1>
        {% if blog.blogTags|length %}
        <div class="tags" style="margin-top:16px;">
            {% for blogTag in blog.blogTags %}
            <a href="/blog/tag/{{ blogTag.tag.seoLink }}" class="tag">{{ blogTag.tag.name }}</a>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    <div class="project-detail-body prose">
        {{ blog.content|raw }}
    </div>

    <div class="project-detail-meta">
        <div class="meta-item">
            <span class="meta-label">Autor</span>
            <span class="meta-value">{{ blog.creator.username }}</span>
        </div>
        <div class="meta-item">
            <span class="meta-label">Veröffentlicht</span>
            <span class="meta-value">{{ blog.created|date("d.m.Y", "Europe/Paris") }}</span>
        </div>
    </div>
</div>
