{% extends 'base.html.twig' %}

{% block title %}byte-artist.de | {{ blog.name }}{% endblock %}

{% block body %}
<div class="page-main">
    <div class="page-hero">
        <div class="page-hero-inner">
            <div class="section-tag">// blog</div>
            <h1>{{ blog.name }}</h1>
        </div>
    </div>
    <div class="page-content">
        {{ include('blog/details.html.twig', { 'blog': blog }) }}

        <div style="margin-top:32px;">
            <a href="{{ path('blog') }}" class="btn-secondary">
                <i class="fas fa-arrow-left"></i>&nbsp; Alle Beiträge
            </a>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('magnific-popup') }}
    {{ encore_entry_script_tags('balanced-gallery') }}
    {{ encore_entry_script_tags('cad-gallery') }}

    <script type="text/javascript">
        jQuery(document).ready(function() {
            jQuery('.cad-gallery').each(function() {
                jQuery(this).BalancedGallery({ /* options */ });
            });

            jQuery('img').each(function() {
                var src = $(this).attr('src');
                if (null !== src) {
                    var image = $('<img />').attr('src', src);
                }
            });

            lazyload();
            createGallery();
        });
    </script>
{% endblock %}