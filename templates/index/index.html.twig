{% extends 'base.html.twig' %}

{% block title %}byte-artist.de | Open-Source Projekte von Andreas{% endblock %}

{% block body %}

{# ═══ HERO ═══ #}
<section class="hero">
    <div class="hero-content">
        <p class="hero-eyebrow">Andreas Kempe</p>
        <h1 class="hero-title">Software Architect<br>aus Dresden.</h1>
        <p class="hero-subtitle">
            Über 35 Jahre Erfahrung in der Softwareentwicklung — von den ersten Zeilen Code auf dem Atari
            bis hin zu Enterprise-Architekturen. Open Source nicht als Hobby, sondern als Überzeugung.
        </p>
        <div class="hero-cta">
            <a href="{{ path('about') }}" class="btn-primary">Über mich</a>
            <a href="{{ path('projects') }}" class="btn-secondary">Projekte</a>
            <a href="{{ path('blog') }}" class="btn-secondary">Blog</a>
        </div>
    </div>
</section>

{# ═══ PROJECTS ═══ #}
{% if projects|length %}
<section class="section">
    <div class="section-header animate-on-scroll">
        <div class="section-tag">// projekte</div>
        <h2 class="section-title">Open-Source Projekte</h2>
        <p class="section-desc">
            Alle meine Projekte sind frei verfügbar — denn Wissen teilen bedeutet gemeinsam wachsen.
        </p>
    </div>

    <div class="cards-grid">
        {% for project in projects %}
        <article class="project-card animate-on-scroll stagger-{{ loop.index <= 3 ? loop.index : '1' }}">
            {% if project.previewPicture %}
            <div class="card-image">
                <a href="/project/{{ project.seoLink }}">
                    <img src="{{ project.previewPicture }}" alt="{{ project.name }}" loading="lazy">
                </a>
                <div class="card-image-overlay"></div>
            </div>
            {% endif %}
            <div class="card-body">
                <h3 class="card-title">
                    <a href="/project/{{ project.seoLink }}">{{ project.name }}</a>
                </h3>
                <p class="card-desc">{{ project.shortDescription }}</p>
            </div>
            <div class="card-footer-bar">
                <span class="card-date">
                    {% if project.modified %}
                        {{ project.modified|date("d.m.Y", "Europe/Berlin") }}
                    {% else %}
                        {{ project.created|date("d.m.Y", "Europe/Berlin") }}
                    {% endif %}
                </span>
                <a href="/project/{{ project.seoLink }}" class="btn-ghost">Details</a>
            </div>
        </article>
        {% endfor %}
    </div>

    <div class="section-actions animate-on-scroll">
        <a href="{{ path('projects') }}" class="btn-secondary">
            Alle Projekte &nbsp;<i class="fas fa-arrow-right"></i>
        </a>
    </div>
</section>
{% endif %}

{# ═══ BLOG ═══ #}
{% if blogs|length %}
<section class="section section--no-top-pad">
    <div class="section-header animate-on-scroll">
        <div class="section-tag">// blog</div>
        <h2 class="section-title">Aktuelle Beiträge</h2>
        <p class="section-desc">Gedanken, Erfahrungen und technische Erkenntnisse aus der Praxis.</p>
    </div>

    <div class="blog-grid">
        {% for blog in blogs %}
        <article class="blog-card animate-on-scroll">
            <div class="blog-card-image">
                <a href="/blog/{{ blog.seoLink }}">
                    <img src="/images/content/dynamisch/blogs/{{ blog.id }}/{{ blog.previewPicture }}"
                         alt="{{ blog.name }}" loading="lazy">
                </a>
            </div>
            <div class="blog-card-body">
                <h3 class="blog-card-title">
                    <a href="/blog/{{ blog.seoLink }}">{{ blog.name }}</a>
                </h3>
                <p class="blog-card-desc">{{ blog.shortDescription }}</p>
                {% if blog.blogTags|length %}
                <div class="tags">
                    {% for blogTag in blog.blogTags %}
                    <a href="/blog/tag/{{ blogTag.tag.seoLink }}" class="tag">{{ blogTag.tag.name }}</a>
                    {% endfor %}
                </div>
                {% endif %}
                <div class="blog-card-meta">
                    <span><i class="fas fa-calendar-alt"></i>&nbsp;{{ blog.created|date("d.m.Y", "Europe/Berlin") }}</span>
                </div>
                <a href="/blog/{{ blog.seoLink }}" class="btn-ghost mt-2">Weiterlesen</a>
            </div>
        </article>
        {% endfor %}
    </div>

    <div class="section-actions animate-on-scroll">
        <a href="{{ path('blog') }}" class="btn-secondary">
            Alle Beiträge &nbsp;<i class="fas fa-arrow-right"></i>
        </a>
    </div>
</section>
{% endif %}

{% endblock %}
