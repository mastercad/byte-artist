{% extends 'base.html.twig' %}

{% block title %}{{ form.vars.value.id ? 'Projekt bearbeiten' : 'Neues Projekt' }}{% endblock %}

{% block body %}
{{ form_start(form, {attr: {id: 'project-form', class: 'editor-form', novalidate: 'novalidate'}}) }}
{{ form_errors(form) }}
{{ form_widget(form.id) }}

{# ── Unsaved-changes guard dialog ── #}
<div id="unsaved-dialog-backdrop" style="display:none" role="dialog" aria-modal="true" aria-labelledby="unsaved-dialog-title">
    <div id="unsaved-dialog">
        <h5 id="unsaved-dialog-title"><i class="fas fa-exclamation-triangle"></i> Ungespeicherte Änderungen</h5>
        <p>Es gibt ungespeicherte Änderungen. Wenn du jetzt verlässt, gehen sie verloren.</p>
        <div class="unsaved-dialog-actions">
            <button type="button" id="unsaved-dialog-stay">Hierbleiben</button>
            <a href="#" id="unsaved-dialog-leave">Trotzdem verlassen</a>
        </div>
    </div>
</div>

<div class="editor-layout">

    {# ── Top bar ── #}
    <div class="editor-topbar">
        <div class="editor-topbar-left">
            <a href="{{ path('projects') }}" class="editor-back-link">
                <i class="fas fa-arrow-left"></i> Zurück zur Übersicht
            </a>
            <h1 class="editor-page-title">
                {% if form.vars.value.id %}
                    <i class="fas fa-edit"></i> Projekt bearbeiten
                {% else %}
                    <i class="fas fa-rocket"></i> Neues Projekt
                {% endif %}
            </h1>
        </div>
        <div class="editor-topbar-right">
            <span class="editor-autosave-hint" id="autosave-hint"></span>
            <button type="submit" class="btn btn-accent btn-save">
                <i class="fas fa-cloud-upload-alt"></i> Speichern
            </button>
        </div>
    </div>

    {# ── Main canvas ── #}
    <div class="editor-canvas">

        {# ─ Left: Main content ─ #}
        <div class="editor-main">

            {# Project name #}
            <div class="editor-section editor-section--title">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>

            {# Short description #}
            <div class="editor-section">
                <div class="editor-section-header">
                    <span class="editor-section-icon"><i class="fas fa-align-left"></i></span>
                    <span class="editor-section-label">Kurzbeschreibung</span>
                    <span class="editor-section-hint">Teaser für die Projektübersicht</span>
                </div>
                {{ form_widget(form.shortDescription) }}
                {{ form_errors(form.shortDescription) }}
            </div>

            {# WYSIWYG Description #}
            <div class="editor-section editor-section--content">
                <div class="editor-section-header">
                    <span class="editor-section-icon"><i class="fas fa-file-code"></i></span>
                    <span class="editor-section-label">Projektbeschreibung</span>
                    <span class="editor-section-hint">Beschreibe das Projekt im Detail</span>
                </div>
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>

            {# Tags #}
            <div class="editor-section">
                <div class="editor-section-header">
                    <span class="editor-section-icon"><i class="fas fa-tags"></i></span>
                    <span class="editor-section-label">Tags / Technologien</span>
                    <span class="editor-section-hint">Klick oder tippe zum Hinzufügen</span>
                </div>
                <div id="tags_container" class="tags-container">
                    <div id="tags_container_clear" class="tags-inner"></div>
                </div>
            </div>

        </div>{# /.editor-main #}

        {# ─ Right: Sidebar ─ #}
        <aside class="editor-sidebar">

            {# Preview image #}
            <div class="sidebar-card">
                <div class="sidebar-card-header">
                    <i class="fas fa-image"></i> Vorschaubild
                </div>
                <div class="sidebar-card-body">
                    <div class="preview-upload-area" id="preview-upload-area">
                        <div class="preview-upload-placeholder" id="preview-placeholder"
                             style="{{ form.vars.value.previewPicture ? 'display:none' : '' }}">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <span>Bild hier ablegen<br>oder klicken zum Auswählen</span>
                        </div>
                        <img id="preview-img" class="preview-img"
                             src="{{ form.vars.value.previewPicture ?: '' }}"
                             style="{{ form.vars.value.previewPicture ? '' : 'display:none' }}" alt="Vorschau">
                    </div>
                    {{ form_widget(form.previewPicture) }}
                    <input type="file" id="preview-file-input" accept="image/*" style="display:none">
                    <button type="button" class="btn btn-outline btn-sm btn-block mt-2"
                            onclick="document.getElementById('preview-file-input').click()">
                        <i class="fas fa-folder-open"></i> Datei wählen
                    </button>
                </div>
            </div>

            {# Links #}
            <div class="sidebar-card">
                <div class="sidebar-card-header">
                    <i class="fas fa-link"></i> Links
                </div>
                <div class="sidebar-card-body">
                    <div class="form-group">
                        {{ form_label(form.link, 'Projekt-URL') }}
                        {{ form_widget(form.link) }}
                        {{ form_errors(form.link) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.originalLink, 'Original-Quelle') }}
                        {{ form_widget(form.originalLink) }}
                        {{ form_errors(form.originalLink) }}
                    </div>
                </div>
            </div>

            {# SEO & Visibility #}
            <div class="sidebar-card">
                <div class="sidebar-card-header">
                    <i class="fas fa-cog"></i> Einstellungen
                </div>
                <div class="sidebar-card-body">
                    <div class="form-group">
                        {{ form_label(form.seoLink, 'URL-Slug') }}
                        <div class="seo-url-preview">
                            <span class="seo-url-base">/project/</span>{{ form_widget(form.seoLink) }}
                        </div>
                        {{ form_errors(form.seoLink) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.state, 'Status') }}
                        {{ form_widget(form.state, {attr: {class: 'form-control'}}) }}
                        {{ form_errors(form.state) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.created, 'Datum') }}
                        {{ form_widget(form.created) }}
                        {{ form_errors(form.created) }}
                    </div>
                    <div class="sidebar-toggle-row">
                        {{ form_widget(form.isPublic) }}
                        {{ form_label(form.isPublic, 'Öffentlich sichtbar') }}
                    </div>
                </div>
            </div>

            {# Shortcuts #}
            <div class="sidebar-card sidebar-card--subtle">
                <div class="sidebar-card-header">
                    <i class="fas fa-keyboard"></i> Shortcuts
                </div>
                <div class="sidebar-card-body shortcuts-list">
                    <div class="shortcut"><kbd>Ctrl+S</kbd> <span>Speichern</span></div>
                    <div class="shortcut"><kbd>Ctrl+B</kbd> <span>Fett</span></div>
                    <div class="shortcut"><kbd>Ctrl+I</kbd> <span>Kursiv</span></div>
                    <div class="shortcut"><kbd>Ctrl+Z</kbd> <span>Rückgängig</span></div>
                </div>
            </div>

        </aside>{# /.editor-sidebar #}

    </div>{# /.editor-canvas #}

</div>{# /.editor-layout #}

{{ form_end(form) }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ vite_entry_link_tags('editor') }}
    <style>
    @keyframes btn-dirty-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.8); }
        50%       { box-shadow: 0 0 0 7px rgba(255, 193, 7, 0); }
    }
    .btn-save.btn-save--dirty {
        outline: 2px solid #ffc107;
        outline-offset: 2px;
        animation: btn-dirty-pulse 1.4s ease-in-out infinite;
    }
    .btn-save.btn-save--uploading {
        border-color: rgba(96,165,250,.7) !important;
        color: rgba(96,165,250,.9) !important;
        outline: 2px solid rgba(96,165,250,.5);
        outline-offset: 2px;
        animation: none;
    }
    #unsaved-dialog-backdrop {
        position: fixed; inset: 0; z-index: 10000;
        background: rgba(0,0,0,.65);
        display: flex; align-items: center; justify-content: center;
    }
    #unsaved-dialog {
        background: var(--bg-2, #1e1e1e);
        border: 1px solid var(--border, #333);
        border-radius: 10px;
        padding: 28px 32px 24px;
        min-width: 340px; max-width: 480px;
        box-shadow: 0 8px 32px rgba(0,0,0,.5);
        color: var(--text, #e0e0e0);
    }
    #unsaved-dialog h5 {
        margin: 0 0 12px; font-size: 1.05rem; font-weight: 600;
    }
    #unsaved-dialog h5 .fa-exclamation-triangle { color: #ffc107; margin-right: 8px; }
    #unsaved-dialog p { margin: 0 0 22px; font-size: .93rem; color: var(--text-muted, #aaa); }
    .unsaved-dialog-actions { display: flex; gap: 10px; justify-content: flex-end; }
    .unsaved-dialog-actions button {
        padding: 7px 18px; border-radius: 6px; border: 1px solid var(--border, #444);
        background: var(--bg-3, #2a2a2a); color: var(--text, #e0e0e0);
        cursor: pointer; font-size: .9rem;
    }
    .unsaved-dialog-actions button:hover { background: var(--bg-4, #333); }
    .unsaved-dialog-actions a {
        padding: 7px 18px; border-radius: 6px; border: 1px solid rgba(239,68,68,.5);
        background: rgba(239,68,68,.15); color: #fca5a5;
        text-decoration: none; font-size: .9rem;
    }
    .unsaved-dialog-actions a:hover { background: rgba(239,68,68,.28); }
    /* ── Field validation errors ─────────────────────────────── */
    .is-invalid {
        border-color: rgba(239,68,68,.7) !important;
        box-shadow: 0 0 0 2px rgba(239,68,68,.25) !important;
    }
    .seo-url-preview:has(.is-invalid) {
        border-color: rgba(239,68,68,.7);
        box-shadow: 0 0 0 2px rgba(239,68,68,.25);
    }
    .field-error-msg {
        margin: 5px 0 0;
        font-size: .82rem;
        color: #fca5a5;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .field-error-msg::before { content: '\26A0\FE0F\00A0'; }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ vite_entry_script_tags('editor') }}
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        'use strict';

        let publicPicturePath = '{{ publicPicturePath }}';
        let isDirty = false;
        let pendingUploads = 0;

        function uploadStart() {
            pendingUploads++;
            isDirty = true;
            let $btn = $('.btn-save');
            $btn.prop('disabled', true)
                .removeClass('btn-save--dirty')
                .addClass('btn-save--uploading')
                .html('<i class="fas fa-spinner fa-spin"></i> Bild wird hochgeladen…');
        }

        function uploadEnd() {
            pendingUploads = Math.max(0, pendingUploads - 1);
            if (pendingUploads === 0) {
                let $btn = $('.btn-save');
                $btn.prop('disabled', false).removeClass('btn-save--uploading');
                if (isDirty) {
                    $btn.addClass('btn-save--dirty').html('<i class="fas fa-cloud-upload-alt"></i> Speichern');
                } else {
                    $btn.html('<i class="fas fa-cloud-upload-alt"></i> Speichern');
                }
            }
        }

        // ── Tag management ──────────────────────────────────────────────
        let tags = [];
        let currentTags = {};
        let autocompleteTags = [];

        {% for projectTag in form.vars.value.projectTags %}
            {% if projectTag.tag and projectTag.tag.name %}
                currentTags["{{ projectTag.tag.id }}"] = {"name": "{{ projectTag.tag.name }}", "id": "{{ projectTag.id }}"};
            {% endif %}
        {% endfor %}

        {% for availableTag in availableTags %}
            if (currentTags[{{ availableTag.id }}] !== undefined) {
                addTag("{{ availableTag.name }}", "{{ availableTag.id }}", currentTags[{{ availableTag.id }}]['id']);
            }
            tags["{{ availableTag.id }}"] = "{{ availableTag.name }}";
            autocompleteTags.push("{{ availableTag.name }}");
        {% endfor %}

        function addTag(name, tagId, projectsTagId, target) {
            let tagSpan = $('<span class="editor-tag"><i class="fas fa-tag tag-icon"></i>' + name +
                '<button type="button" class="tag-remove" title="Entfernen"><i class="fas fa-times"></i></button>' +
                '</span>')
                .attr('data-projects-tag-id', projectsTagId !== undefined ? projectsTagId : '')
                .attr('data-id', tagId !== undefined ? tagId : '')
                .attr('data-name', name);
            let insertTarget = target || $('#tags_container_clear');
            tagSpan.insertBefore(insertTarget);
            tagSpan.find('.tag-remove').on('click', function() { tagSpan.remove(); });
        }

        function initTagAutocomplete() {
            let $input = $('#tag-autocomplete-input');
            $input.autocomplete({
                minLength: 0,
                source: autocompleteTags,
                select: function(event, ui) {
                    tags.forEach(function(tag, id) {
                        if (tag === ui.item.value) {
                            if ($("#tags_container [data-id='" + id + "']").length === 0) {
                                addTag(tag, id, undefined);
                            }
                        }
                    });
                    $input.val('');
                    return false;
                }
            });
            $input.on('keydown', function(e) {
                if (e.keyCode === 13) {
                    e.preventDefault();
                    let val = $(this).val().trim();
                    if (val) { addTag(val, undefined, undefined); $(this).val(''); }
                }
            });
        }

        function extendDataWithTags(data) {
            let counter = 0;
            $('#tags_container .editor-tag').each(function() {
                data.push({name: 'projects[projectTags][' + counter + '][id]',      value: $(this).data('projects-tag-id')});
                data.push({name: 'projects[projectTags][' + counter + '][tagId]',   value: $(this).data('id')});
                data.push({name: 'projects[projectTags][' + counter + '][tagName]', value: $(this).data('name')});
                ++counter;
            });
            return data;
        }

        // ── Preview image upload ────────────────────────────────────────
        function initPreviewUpload() {
            let $area      = $('#preview-upload-area');
            let $imgEl     = $('#preview-img');
            let $placeholder = $('#preview-placeholder');
            let $hidden    = $('#projects_previewPicture');
            let $fileInput = $('#preview-file-input');

            function showPreview(src) {
                $imgEl.attr('src', src).show();
                $placeholder.hide();
            }

            function uploadFile(file) {
                let reader = new FileReader();
                reader.onload = function(ev) {
                    // Sofort anzeigen (Data-URI), kein Warten auf Server
                    showPreview(ev.target.result);
                    let $overlay = $('<div class="preview-upload-overlay"><i class="fas fa-spinner fa-spin"></i><span>Wird hochgeladen…</span></div>');
                    $area.addClass('uploading').append($overlay);
                    uploadStart();

                    $.post('/project/upload/preview', {
                        fileData: ev.target.result,
                        name: file.name
                    }, function(response) {
                        $overlay.remove();
                        $area.removeClass('uploading');
                        uploadEnd();
                        if (response && response.url) {
                            $imgEl.attr('src', response.url + '?' + Date.now());
                            $hidden.val(response.url);
                        } else {
                            // Fallback: Data-URI im Hidden-Field behalten
                            $hidden.val(ev.target.result);
                        }
                    }).fail(function() {
                        $overlay.remove();
                        $area.removeClass('uploading');
                        uploadEnd();
                        // Bild bleibt als Data-URI sichtbar, nur hidden field
                        $hidden.val(ev.target.result);
                    });
                };
                reader.readAsDataURL(file);
            }

            $fileInput.on('change', function() {
                if (this.files[0]) uploadFile(this.files[0]);
            });

            $area.on('dragover', function(e) {
                e.preventDefault(); $(this).addClass('drag-over');
            }).on('dragleave', function(e) {
                e.preventDefault(); $(this).removeClass('drag-over');
            }).on('drop', function(e) {
                e.preventDefault(); $(this).removeClass('drag-over');
                let files = e.originalEvent.dataTransfer.files;
                if (files.length) uploadFile(files[0]);
            });
        }

        // ── Save ────────────────────────────────────────────────────────
        function clearFieldErrors() {
            $('.field-error-msg').remove();
            $('.is-invalid').removeClass('is-invalid');
        }

        function showFieldErrors(errors, prefix) {
            clearFieldErrors();
            var firstInput = null;
            Object.keys(errors).forEach(function(field) {
                var msgs = errors[field];
                var text = Array.isArray(msgs)
                    ? msgs.filter(function(m) { return typeof m === 'string'; }).join(' ')
                    : (typeof msgs === 'string' ? msgs : '');
                if (!text) return;
                var $input = $('#' + prefix + '_' + field);
                if (!$input.length) return;
                $input.addClass('is-invalid');
                var $anchor = $input.closest('.seo-url-preview').length
                    ? $input.closest('.seo-url-preview')
                    : $input;
                $('<p class="field-error-msg"></p>').text(text).insertAfter($anchor);
                if (!firstInput) { firstInput = $input[0]; }
            });
            if (firstInput) {
                var section = firstInput.closest('.editor-section, .form-group, .sidebar-card');
                if (section) { section.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
            }
        }

        function save() {
            if (pendingUploads > 0) {
                showToast('Bitte warte, bis alle Bilder fertig hochgeladen sind.', 'warning');
                return;
            }
            // Filter out the empty projectTags hidden field – it conflicts with the
            // array-notation entries added by extendDataWithTags (PHP would keep the
            // scalar '' and silently drop all array keys for the same name).
            let data = $('#project-form').serializeArray().filter(function(item) {
                return item.name !== 'projects[projectTags]';
            });
            data = extendDataWithTags(data);
            let $btn = $('.btn-save');
            $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Speichern...');

            $.post('/project/save', data, function(response) {
                clearFieldErrors();
                $btn.prop('disabled', false).removeClass('btn-save--dirty').html('<i class="fas fa-check"></i> Gespeichert');
                isDirty = false;
                $('#autosave-hint').text('Zuletzt gespeichert: ' + new Date().toLocaleTimeString('de-DE'));
                if (response && response.id) {
                    $('#projects_id').val(response.id);
                }
                setTimeout(function() {
                    $btn.html('<i class="fas fa-cloud-upload-alt"></i> Speichern');
                }, 3000);
            }).fail(function(jqXHR) {
                $btn.prop('disabled', false).html('<i class="fas fa-cloud-upload-alt"></i> Speichern');
                if (jqXHR.status === 422 && jqXHR.responseJSON) {
                    showFieldErrors(jqXHR.responseJSON, 'projects');
                    showToast('Bitte fülle alle Pflichtfelder korrekt aus.', 'error');
                } else {
                    let msg = 'Fehler beim Speichern.';
                    if (jqXHR.responseJSON) {
                        if (jqXHR.responseJSON.id) {
                            $('#projects_id').val(jqXHR.responseJSON.id);
                        }
                        let errs = $.extend({}, jqXHR.responseJSON);
                        delete errs.id;
                        let text = Object.values(errs).flat().join('\n');
                        if (text) { msg = text; }
                    }
                    showToast(msg, 'error');
                }
            });
        }

        // ── Boot ────────────────────────────────────────────────────────
        $(function() {
            // ── Dirty tracking ──────────────────────────────────────────
            function markDirty() {
                isDirty = true;
                $('.btn-save').addClass('btn-save--dirty');
            }
            $('#project-form').on('input change', markDirty);

            // Intercept in-page link navigation → show custom dialog
            $(document).on('click', 'a[href]', function(e) {
                let href = $(this).attr('href');
                if (!isDirty || !href || href === '#' || href.startsWith('#') || $(this).closest('#unsaved-dialog-backdrop').length) return;
                e.preventDefault();
                $('#unsaved-dialog-leave').attr('href', href);
                $('#unsaved-dialog-backdrop').css('display', 'flex');
            });
            $('#unsaved-dialog-stay').on('click', function() {
                $('#unsaved-dialog-backdrop').hide();
            });
            $('#unsaved-dialog-backdrop').on('click', function(e) {
                if (e.target === this) $(this).hide();
            });

            // Intercept F5 / Ctrl+R reload shortcuts
            document.addEventListener('keydown', function(e) {
                if (!isDirty) return;
                let isReload = e.key === 'F5' || (e.ctrlKey && e.key.toLowerCase() === 'r');
                if (!isReload) return;
                e.preventDefault();
                $('#unsaved-dialog-leave').attr('href', window.location.href);
                $('#unsaved-dialog-backdrop').css('display', 'flex');
            });

            // Toolbar reload / tab close — browser forces its own native dialog here
            window.addEventListener('beforeunload', function(e) {
                if (isDirty) { e.preventDefault(); e.returnValue = ''; }
            });

            $('#projects_projectTags').closest('.form-group').remove();

            let $tagInput = $('<input id="tag-autocomplete-input" class="tag-input" placeholder="Technologie oder Tag hinzufügen ..." type="text">');
            $('#tags_container_clear').before($tagInput);
            initTagAutocomplete();

            initPreviewUpload();

            // Track Tiptap inline-image uploads
            $('#project-form').on('editorUploadStart', uploadStart);
            $('#project-form').on('editorUploadEnd',   uploadEnd);

            $('.btn-save').on('click', function(e) {
                e.preventDefault();
                save();
            });

            $(document).on('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                    e.preventDefault();
                    save();
                }
            });
        });
    });
    </script>
{% endblock %}

