<div class="project-detail">
    <div class="project-detail-header">
        {% if is_granted('edit', project) or is_granted('delete', project) %}
        <div class="project-detail-actions">
            {% if is_granted('edit', project) %}
            <a class="btn-secondary" style="padding:8px 16px;font-size:13px;" href="/project/create/{{ project.id }}">
                <i class="fas fa-edit"></i> Bearbeiten
            </a>
            {% endif %}
            {% if is_granted('delete', project) %}
            <button class="btn-secondary btn-delete-project"
                    data-delete-url="/project/delete/{{ project.id }}"
                    data-redirect="/portfolio"
                    style="padding:8px 16px;font-size:13px;color:#fca5a5;border-color:rgba(239,68,68,0.3);cursor:pointer;">
                <i class="fas fa-trash"></i> Löschen
            </button>
            <script>
            document.querySelector('.btn-delete-project').addEventListener('click', function() {
                if (!confirm('Projekt wirklich löschen?')) { return; }
                var btn = this;
                btn.disabled = true;
                $.get(btn.dataset.deleteUrl)
                    .done(function() { window.location.href = btn.dataset.redirect; })
                    .fail(function() { btn.disabled = false; showToast('Fehler beim Löschen.', 'error'); });
            });
            </script>
            {% endif %}
        </div>
        {% endif %}
        <h1>{{ project.name }}</h1>
        {% if project.projectTags|length %}
        <div class="tags" style="margin-top:16px;">
            {% for projectTag in project.projectTags %}
            <a href="/project/tag/{{ projectTag.tag.seoLink }}" class="tag">{{ projectTag.tag.name }}</a>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    <div class="project-detail-body prose">
        {{ project.description|raw }}
    </div>

    <div class="project-detail-meta">
        <div class="meta-item">
            <span class="meta-label">Autor</span>
            <span class="meta-value">{{ project.creator.username }}</span>
        </div>
        <div class="meta-item">
            <span class="meta-label">Erstellt</span>
            <span class="meta-value">{{ project.created|date("d.m.Y", "Europe/Berlin") }}</span>
        </div>
        {% if project.modified %}
        <div class="meta-item">
            <span class="meta-label">Aktualisiert</span>
            <span class="meta-value">{{ project.modified|date("d.m.Y", "Europe/Berlin") }}</span>
        </div>
        {% endif %}
    </div>
</div>
