{% extends 'base.html.twig' %}

{% block title %}byte-artist.de | Projekte{% endblock %}

{% block body %}
<main class="page-main">
    <div class="page-hero">
        <div class="page-hero-inner">
            <div class="section-tag">// projekte</div>
            <h1>Open-Source Projekte</h1>
            <p>Alle Projekte sind frei verfügbar — weil Wissen geteilt werden sollte.</p>
        </div>
    </div>

    <div class="page-content">
        {% if is_granted('ROLE_ADMIN') %}
        <div class="mb-4">
            <a href="{{ path('project_create') }}" class="btn-primary"><i class="fas fa-plus"></i>&nbsp; Neues Projekt</a>
        </div>
        {% endif %}
        {{ include('fragment/pagination.html.twig') }}

        <div class="two-col-layout mt-5">
            <div>
                <div class="cards-grid">
                    {% for project in projects %}
                        {{ include('projects/preview_template_left.html.twig', { 'project': project }) }}
                    {% endfor %}
                </div>
            </div>

            <aside class="sidebar">
                {% if projectTags|length %}
                <div class="sidebar-widget">
                    <div class="sidebar-title">Tags</div>
                    <div class="tag-cloud-pills">
                        {% for projectTag in projectTags %}
                        <a href="/project/tag/{{ projectTag.tag.seoLink }}" class="tag">{{ projectTag.tag.name }}</a>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </aside>
        </div>

        {{ include('fragment/pagination.html.twig') }}
    </div>
</main>
{% endblock %}
