<article class="project-card animate-on-scroll{% if not project.isPublic %} project-card--draft{% endif %}">
    {% if not project.isPublic %}
    <span class="draft-badge"><i class="fas fa-eye-slash"></i> Entwurf</span>
    {% endif %}
    {% if project.previewPicture %}
    <div class="card-image">
        <a href="/project/{{ project.seoLink }}">
            <img src="{{ project.previewPicture }}" alt="{{ project.name }}" loading="lazy">
        </a>
        <div class="card-image-overlay"></div>
    </div>
    {% endif %}
    <div class="card-body">
        <h2 class="card-title">
            <a href="/project/{{ project.seoLink }}">{{ project.name }}</a>
        </h2>
        <p class="card-desc">{{ project.shortDescription }}</p>
        {% if project.ProjectTags|length %}
        <div class="tags" style="margin-top:4px;">
            {% for projectTag in project.ProjectTags %}
            <a href="/project/tag/{{ projectTag.tag.seoLink }}" class="tag">{{ projectTag.tag.name }}</a>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    <div class="card-footer-bar">
        <span class="card-date">
            {% if project.modified %}{{ project.modified|date("d.m.Y", "Europe/Berlin") }}{% else %}{{ project.created|date("d.m.Y", "Europe/Berlin") }}{% endif %}
        </span>
        <a href="/project/{{ project.seoLink }}" class="btn-ghost">Details</a>
    </div>
</article>
