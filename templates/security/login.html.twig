{% extends 'base.html.twig' %}

{% block title %}byte-artist.de | Anmelden{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <h1>Anmelden</h1>

        {% if error %}
        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user is not null %}
        <div class="alert alert-info">
            Angemeldet als {{ app.user.username }}. <a href="{{ path('app_logout') }}">Abmelden</a>
        </div>
        {% endif %}

        <form method="post">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label class="form-label" for="inputUsername">E-Mail</label>
                <input type="text" value="{{ last_username }}" name="email" id="inputUsername"
                       class="form-control" placeholder="name@example.com" required autofocus autocomplete="email">
            </div>

            <div class="form-group">
                <label class="form-label" for="inputPassword">Passwort</label>
                <input type="password" name="password" id="inputPassword"
                       class="form-control" placeholder="••••••••" required autocomplete="current-password">
            </div>

            <button class="btn-primary" type="submit" style="width:100%;justify-content:center;margin-top:8px;">
                Anmelden
            </button>
        </form>

        <div style="margin-top:20px;text-align:center;">
            <a href="{{ path('connect_google_start') }}" class="btn-secondary" style="width:100%;justify-content:center;">
                <i class="fab fa-google"></i>&nbsp; Mit Google anmelden
            </a>
        </div>
    </div>
</div>
{% endblock %}
